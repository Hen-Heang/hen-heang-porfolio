# Supabase — public content reads (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only admin operations (contact form insert, etc). Never expose to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant (Vercel AI SDK + OpenAI Responses API). Without OPENAI_API_KEY,
# the assistant returns a graceful "not configured" message instead of erroring.
OPENAI_API_KEY=
# Default model for ordinary portfolio/recruiter Q&A. Falls back to a built-in default if unset.
OPENAI_MODEL=
# Used only for questions that need real analysis — comparisons, role-fit judgment,
# architecture trade-offs — selected automatically by src/lib/ai/models.ts. Optional.
OPENAI_DEEP_MODEL=
# Resilience fallback: used when a visitor explicitly retries a failed/unsatisfying
# answer (never used as a primary route). Optional.
OPENAI_FALLBACK_MODEL=

# Gates the live-model portion of the assistant eval suite (src/lib/ai/evals/live-model.test.ts),
# which makes real OpenAI API calls and costs real tokens. Leave unset for normal `pnpm test` runs.
RUN_LIVE_EVALS=

# Distributed rate limiting (AI chat + contact form) via Upstash Redis.
# Optional — without these, rate limiting falls back to an in-memory limiter
# that works for local dev but is NOT correct across multiple serverless
# instances in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
