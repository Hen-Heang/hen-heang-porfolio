# Supabase — public content reads (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only admin operations (contact form insert, etc). Never expose to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant (Vercel AI SDK + OpenAI). Without this, the assistant returns a
# graceful "not configured" message instead of erroring.
OPENAI_API_KEY=
OPENAI_MODEL=

# Distributed rate limiting (AI chat + contact form) via Upstash Redis.
# Optional — without these, rate limiting falls back to an in-memory limiter
# that works for local dev but is NOT correct across multiple serverless
# instances in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
